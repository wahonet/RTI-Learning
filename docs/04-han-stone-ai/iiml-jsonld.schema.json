{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/docs/04-han-stone-ai/iiml-jsonld.schema.json",
  "title": "IIML JSON-LD Working Draft",
  "description": "A pragmatic JSON-LD schema draft for iconography annotations, RTI-derived resources, and knowledge graph export.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "@context",
    "@type",
    "documentId",
    "name",
    "resources",
    "annotations"
  ],
  "properties": {
    "@context": {
      "description": "Versioned JSON-LD context URI or inline context object.",
      "oneOf": [
        {
          "type": "string",
          "format": "uri"
        },
        {
          "type": "object",
          "additionalProperties": true
        },
        {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string",
                "format": "uri"
              },
              {
                "type": "object",
                "additionalProperties": true
              }
            ]
          }
        }
      ]
    },
    "@type": {
      "const": "IIMLDocument"
    },
    "documentId": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "name": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "default": "0.1.0"
    },
    "language": {
      "type": "string",
      "default": "zh-CN"
    },
    "culturalObject": {
      "$ref": "#/$defs/culturalObject"
    },
    "resources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/resource"
      },
      "minItems": 1
    },
    "annotations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/annotation"
      }
    },
    "relations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/relation"
      },
      "default": []
    },
    "vocabularies": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/vocabularyTerm"
      },
      "default": []
    },
    "processingRuns": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/processingRun"
      },
      "default": []
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "uriOrUrn": {
      "type": "string",
      "pattern": "^(?:(?:https?|file|s3|ipfs)://\\S+|urn:[A-Za-z0-9][A-Za-z0-9_.:-]*:.+|[A-Za-z0-9_.:/#?=&%+~,-]+)$"
    },
    "isoDateTime": {
      "type": "string",
      "format": "date-time"
    },
    "id": {
      "description": "Stable local ID, URI, or URN.",
      "$ref": "#/$defs/nonEmptyString"
    },
    "culturalObject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "objectId",
        "name"
      ],
      "properties": {
        "objectId": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "objectType": {
          "type": "string",
          "examples": [
            "stone_relief",
            "rubbing",
            "inscription",
            "artifact"
          ]
        },
        "period": {
          "type": "string"
        },
        "location": {
          "type": "string"
        },
        "material": {
          "type": "string"
        },
        "dimensions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "width": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "height": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "depth": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "unit": {
              "type": "string",
              "default": "mm"
            }
          }
        },
        "currentRepository": {
          "type": "string"
        },
        "rights": {
          "type": "string"
        },
        "references": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/reference"
          },
          "default": []
        }
      }
    },
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "uri"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "type": {
          "enum": [
            "IIIFImage",
            "Image",
            "ImageSequence",
            "RTI",
            "PTM",
            "HSH",
            "RBF",
            "NormalMap",
            "HeightMap",
            "DepthMap",
            "LineDrawing",
            "DigitalRubbing",
            "GrayscaleImage",
            "Mesh3D",
            "PointCloud",
            "MultispectralLayer",
            "Audio",
            "Video",
            "Document",
            "Other"
          ]
        },
        "uri": {
          "$ref": "#/$defs/uriOrUrn"
        },
        "name": {
          "type": "string"
        },
        "format": {
          "type": "string",
          "examples": [
            "image/jpeg",
            "image/tiff",
            "application/json",
            "model/gltf+json"
          ]
        },
        "width": {
          "type": "integer",
          "exclusiveMinimum": 0
        },
        "height": {
          "type": "integer",
          "exclusiveMinimum": 0
        },
        "coordinateSystem": {
          "$ref": "#/$defs/coordinateSystem"
        },
        "derivedFrom": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "default": []
        },
        "processingRunId": {
          "$ref": "#/$defs/id"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "coordinateSystem": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "enum": [
            "pixel",
            "physical",
            "world3d",
            "time",
            "spectral"
          ],
          "default": "pixel"
        },
        "origin": {
          "type": "string",
          "default": "top-left"
        },
        "unit": {
          "type": "string",
          "default": "px"
        },
        "transform": {
          "description": "Optional affine or projective transform matrix stored row-major.",
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "type": "number"
            },
            "minItems": 3,
            "maxItems": 4
          },
          "minItems": 2,
          "maxItems": 4
        }
      }
    },
    "annotation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "resourceId",
        "target",
        "structuralLevel"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "type": {
          "const": "Annotation",
          "default": "Annotation"
        },
        "resourceId": {
          "$ref": "#/$defs/id"
        },
        "target": {
          "$ref": "#/$defs/geometry"
        },
        "structuralLevel": {
          "enum": [
            "whole",
            "scene",
            "figure",
            "component",
            "trace",
            "inscription",
            "damage",
            "unknown"
          ]
        },
        "label": {
          "type": "string"
        },
        "semantics": {
          "$ref": "#/$defs/semantics"
        },
        "contains": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/annotation"
          },
          "default": []
        },
        "partOf": {
          "$ref": "#/$defs/id"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "generation": {
          "$ref": "#/$defs/generation"
        },
        "reviewStatus": {
          "enum": [
            "candidate",
            "reviewed",
            "approved",
            "rejected"
          ],
          "default": "candidate"
        },
        "createdBy": {
          "type": "string"
        },
        "createdAt": {
          "$ref": "#/$defs/isoDateTime"
        },
        "updatedAt": {
          "$ref": "#/$defs/isoDateTime"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "geometry": {
      "oneOf": [
        {
          "$ref": "#/$defs/pointGeometry"
        },
        {
          "$ref": "#/$defs/lineStringGeometry"
        },
        {
          "$ref": "#/$defs/polygonGeometry"
        },
        {
          "$ref": "#/$defs/multiPolygonGeometry"
        },
        {
          "$ref": "#/$defs/bboxGeometry"
        }
      ]
    },
    "point": {
      "type": "array",
      "items": {
        "type": "number"
      },
      "minItems": 2,
      "maxItems": 4
    },
    "linearRing": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/point"
      },
      "minItems": 4
    },
    "pointGeometry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "coordinates"
      ],
      "properties": {
        "type": {
          "const": "Point"
        },
        "coordinates": {
          "$ref": "#/$defs/point"
        }
      }
    },
    "lineStringGeometry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "coordinates"
      ],
      "properties": {
        "type": {
          "const": "LineString"
        },
        "coordinates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/point"
          },
          "minItems": 2
        }
      }
    },
    "polygonGeometry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "coordinates"
      ],
      "properties": {
        "type": {
          "const": "Polygon"
        },
        "coordinates": {
          "description": "GeoJSON-style polygon coordinates: an array of linear rings. The first ring is the exterior boundary.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/linearRing"
          },
          "minItems": 1
        }
      }
    },
    "multiPolygonGeometry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "coordinates"
      ],
      "properties": {
        "type": {
          "const": "MultiPolygon"
        },
        "coordinates": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/linearRing"
            },
            "minItems": 1
          },
          "minItems": 1
        }
      }
    },
    "bboxGeometry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "coordinates"
      ],
      "properties": {
        "type": {
          "const": "BBox"
        },
        "coordinates": {
          "description": "[minX, minY, maxX, maxY]",
          "type": "array",
          "items": {
            "type": "number"
          },
          "minItems": 4,
          "maxItems": 4
        }
      }
    },
    "semantics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "material": {
          "type": "string"
        },
        "technique": {
          "type": "string"
        },
        "iconographicMeaning": {
          "description": "Object-level identification, such as person, animal, plant, object, motif, or inscription.",
          "type": "string"
        },
        "iconologicalMeaning": {
          "description": "Cultural, symbolic, or interpretive meaning.",
          "type": "string"
        },
        "inscription": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "transcription": {
              "type": "string"
            },
            "translation": {
              "type": "string"
            },
            "readingNote": {
              "type": "string"
            }
          }
        },
        "terms": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/termRef"
          },
          "default": []
        },
        "attributes": {
          "type": "object",
          "additionalProperties": {
            "type": [
              "string",
              "number",
              "boolean",
              "null"
            ]
          }
        }
      }
    },
    "termRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "label": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "scheme": {
          "type": "string",
          "examples": [
            "CIT",
            "ICONCLASS",
            "Wikidata",
            "AAT"
          ]
        },
        "role": {
          "type": "string",
          "examples": [
            "iconographic",
            "iconological",
            "material",
            "technique"
          ]
        }
      }
    },
    "vocabularyTerm": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "prefLabel"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "prefLabel": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "altLabel": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "scheme": {
          "type": "string"
        },
        "definition": {
          "type": "string"
        },
        "broader": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "default": []
        },
        "narrower": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "default": []
        },
        "exactMatch": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/uriOrUrn"
          },
          "default": []
        },
        "closeMatch": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/uriOrUrn"
          },
          "default": []
        },
        "seeAlso": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/uriOrUrn"
          },
          "default": []
        }
      }
    },
    "relation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "subject",
        "predicate",
        "object"
      ],
      "properties": {
        "subject": {
          "$ref": "#/$defs/id"
        },
        "predicate": {
          "enum": [
            "contains",
            "partOf",
            "above",
            "below",
            "leftOf",
            "rightOf",
            "overlaps",
            "intersects",
            "faces",
            "holds",
            "rides",
            "attacks",
            "actsOn",
            "sameAs",
            "exactMatch",
            "closeMatch",
            "broader",
            "narrower",
            "seeAlso",
            "derivedFrom",
            "supersedes",
            "alternativeInterpretationOf"
          ]
        },
        "object": {
          "$ref": "#/$defs/id"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "source": {
          "$ref": "#/$defs/reference"
        },
        "note": {
          "type": "string"
        }
      }
    },
    "processingRun": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "method"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "method": {
          "type": "string",
          "examples": [
            "rti-fit",
            "photometric-stereo",
            "normal-enhancement",
            "line-extraction",
            "sam-segmentation",
            "sonification"
          ]
        },
        "software": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "parameters": {
          "type": "object",
          "additionalProperties": true
        },
        "inputResourceIds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "default": []
        },
        "outputResourceIds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "default": []
        },
        "createdAt": {
          "$ref": "#/$defs/isoDateTime"
        },
        "createdBy": {
          "type": "string"
        }
      }
    },
    "generation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method"
      ],
      "properties": {
        "method": {
          "type": "string",
          "examples": [
            "manual",
            "sam",
            "opencv",
            "model-assisted",
            "imported"
          ]
        },
        "model": {
          "type": "string"
        },
        "modelVersion": {
          "type": "string"
        },
        "prompt": {
          "type": "object",
          "additionalProperties": true
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "reviewStatus": {
          "enum": [
            "candidate",
            "reviewed",
            "approved",
            "rejected"
          ],
          "default": "candidate"
        }
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "reference": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string"
        },
        "uri": {
          "$ref": "#/$defs/uriOrUrn"
        },
        "citation": {
          "type": "string"
        },
        "note": {
          "type": "string"
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "createdBy": {
          "type": "string"
        },
        "createdAt": {
          "$ref": "#/$defs/isoDateTime"
        },
        "updatedBy": {
          "type": "string"
        },
        "updatedAt": {
          "$ref": "#/$defs/isoDateTime"
        },
        "sourceReferences": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/reference"
          },
          "default": []
        },
        "license": {
          "type": "string"
        }
      }
    }
  }
}
